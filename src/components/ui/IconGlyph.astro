---
interface Props {
  name:
    | 'shield'
    | 'network'
    | 'scaling'
    | 'clock'
    | 'check'
    | 'pulse'
    | 'server'
    | 'building'
    | 'finance'
    | 'truck'
    | 'spark'
    | 'flask';
