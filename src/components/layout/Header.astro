---
import Button from '../ui/Button.astro';
import { navigation, siteConfig } from '../../data/site';

const pathname = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? pathname === '/' : pathname.startsWith(href));
---

<header id="site-header" class="fixed top-0 z-50 w-full px-4 pt-4 sm:px-6">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-6 rounded-2xl bg-white/25 px-5 py-3 shadow-[0_8px_32px_rgba(9,36,45,0.07)] backdrop-blur-xl">

    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center" aria-label={`Ir para a home da ${siteConfig.name}`}>
      <img
        src={`${import.meta.env.BASE_URL}images/solutions/logo_monte.svg`}
        alt=""
        class="h-13 w-auto sm:h-14"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Nav desktop -->
    <nav class="hidden items-center gap-6 lg:flex" aria-label="Principal">
      {
        navigation.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={['nav-link', isActive(item.href) && 'nav-link-active']}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- CTA desktop -->
    <div class="hidden shrink-0 lg:block">
      <Button href="/contato" variant="primary" size="sm">Fale com a Monte Sião</Button>
    </div>

    <!-- Menu mobile -->
    <details class="group relative lg:hidden">
      <summary class="flex size-10 cursor-pointer list-none items-center justify-center rounded-xl border border-primary/12 bg-muted text-primary marker:hidden transition hover:bg-primary/8">
        <span class="sr-only">Abrir navegação</span>
        <div class="flex flex-col gap-[5px]">
          <span class="h-0.5 w-5 rounded-full bg-current transition-all group-open:translate-y-[7px] group-open:rotate-45"></span>
          <span class="h-0.5 w-5 rounded-full bg-current transition-all group-open:opacity-0"></span>
          <span class="h-0.5 w-5 rounded-full bg-current transition-all group-open:-translate-y-[7px] group-open:-rotate-45"></span>
        </div>
      </summary>
      <div class="absolute right-0 top-[calc(100%+0.6rem)] w-64 rounded-2xl border border-primary/10 bg-surface p-4 shadow-[--shadow-panel]">
        <nav class="flex flex-col gap-1" aria-label="Mobile">
          {
            navigation.map((item) => (
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'rounded-xl px-4 py-2.5 text-sm font-medium text-text-soft transition hover:bg-muted hover:text-primary',
                  isActive(item.href) && 'bg-muted text-primary',
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
        <div class="mt-3 border-t border-muted pt-3">
          <Button href="/contato" variant="primary" className="w-full justify-center">Contato institucional</Button>
        </div>
      </div>
    </details>
  </div>
</header>

<script>
  const navbar = document.querySelector('#site-header > div') as HTMLElement | null;
  const hero = document.getElementById('hero');

  function update() {
    const heroBottom = hero ? hero.getBoundingClientRect().bottom : 0;
    const pastHero = heroBottom <= 0;

    if (pastHero) {
      navbar?.classList.add('bg-white/80');
      navbar?.classList.remove('bg-white/25');
      document.querySelectorAll('.nav-link').forEach((el) => {
        el.classList.remove('text-white/80', 'hover:text-white', 'text-white');
        el.classList.add('text-text', 'hover:text-primary');
      });
      document.querySelectorAll('.nav-link-active').forEach((el) => {
        el.classList.remove('text-white');
        el.classList.add('text-primary');
      });
    } else {
      navbar?.classList.remove('bg-white/80');
      navbar?.classList.add('bg-white/25');
      document.querySelectorAll('.nav-link').forEach((el) => {
        el.classList.remove('text-text', 'hover:text-primary');
        el.classList.add('text-white/80', 'hover:text-white');
      });
      document.querySelectorAll('.nav-link-active').forEach((el) => {
        el.classList.remove('text-primary');
        el.classList.add('text-white');
      });
    }
  }

  update();
  window.addEventListener('scroll', update, { passive: true });
</script>
