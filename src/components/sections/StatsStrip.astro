---
import Container from '../ui/Container.astro';
import StatCard from '../ui/StatCard.astro';

interface Metric {
  value: string;
  label: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---

<section class="section-space pt-0">
  <Container>
    <div class="panel-dark px-6 py-8 md:px-10">
      <div class="flex flex-col gap-5 border-b border-white/10 pb-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-accent-soft">Números institucionais</p>
          <h2 class="mt-3 text-3xl text-white">Uma estrutura pensada para amplitude, integração e continuidade.</h2>
        </div>
        <p class="max-w-xl text-sm leading-7 text-white/72">
          Indicadores sintetizam a capacidade da holding de operar, sustentar e expandir soluções em contextos diversos.
        </p>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-4">
        {metrics.map((metric) => <StatCard value={metric.value} label={metric.label} dark />)}
      </div>
    </div>
  </Container>
</section>
