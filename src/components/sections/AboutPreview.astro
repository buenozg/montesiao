---
import Container from '../ui/Container.astro';
import SectionIntro from '../ui/SectionIntro.astro';

interface Highlight {
  title: string;
  description: string;
}

interface Props {
  highlights: Highlight[];
}

const { highlights } = Astro.props;
---

<section class="section-space">
  <Container>
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <SectionIntro
        eyebrow="Quem somos"
        title="Uma holding preparada para conectar competências, integrar operações e apoiar crescimento com consistência."
        description="Monte Sião estrutura um ecossistema de empresas com atuação complementar. O grupo opera com visão executiva compartilhada, governança unificada e foco em serviços essenciais que exigem escala, previsibilidade e continuidade."
      />
      <div class="panel p-8">
        <div class="grid gap-6 md:grid-cols-3">
          {
            highlights.map((item) => (
              <div class="rounded-3xl border border-primary/8 bg-muted/45 p-5">
                <h3 class="text-xl">{item.title}</h3>
                <p class="mt-3 text-sm leading-7 text-text-soft">{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>
